.lobby-page {
  background: #f5f7fb;
}

.header {
  padding: 12rpx 0 36rpx;
  margin-bottom: 8rpx;
}

.header-kicker {
  display: inline-block;
  padding: 8rpx 14rpx;
  margin-bottom: 18rpx;
  color: #2b5b3f;
  background: #e7f5ec;
  border: 1rpx solid #cce8d5;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.title {
  display: block;
  color: #111418;
  font-size: 52rpx;
  font-weight: 700;
  line-height: 1.15;
}

.subtitle {
  display: block;
  max-width: 620rpx;
  margin-top: 16rpx;
  color: #5f6877;
  font-size: 27rpx;
  line-height: 1.6;
}

.status-line {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 24rpx;
}

.status-line text {
  padding: 8rpx 14rpx;
  color: #505a68;
  background: #ffffff;
  border: 1rpx solid #e4e8ef;
  border-radius: 8rpx;
  font-size: 23rpx;
}

.action-panel {
  box-shadow: 0 16rpx 44rpx rgba(31, 41, 55, 0.07);
}

.create-panel {
  padding-bottom: 32rpx;
}

.hero-button {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
  height: 116rpx;
  padding: 0 32rpx;
  margin-top: 28rpx;
  background: linear-gradient(135deg, #1f6feb 0%, #174ea6 100%);
  box-shadow: 0 16rpx 30rpx rgba(31, 111, 235, 0.24);
  line-height: 1;
  text-align: left;
}

.button-title {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.2;
}

.button-subtitle {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 22rpx;
  line-height: 1.2;
}

.join-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin: 22rpx 0 16rpx;
}

.room-input {
  flex: 1;
  margin-bottom: 0;
  font-weight: 600;
  letter-spacing: 0;
}

.join-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 168rpx;
  min-width: 168rpx;
  height: 88rpx;
  padding: 0;
  margin: 0;
  color: #123c2b;
  background: #dff5e8;
  border: 1rpx solid #b8e3c8;
  font-weight: 700;
  line-height: 1;
}
