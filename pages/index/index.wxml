<view class="page">
  <view class="header">
    <text class="title">房间大厅</text>
    <text class="subtitle">创建一个房间，或输入房号加入朋友的房间。</text>
  </view>

  <view class="section">
    <view class="section-title">创建房间</view>
    <text class="muted">创建后会自动进入房间，后续游戏会接入房间状态。</text>
    <button class="primary-button top-gap" loading="{{creating}}" disabled="{{creating || joining}}" bindtap="handleCreateRoom">
      创建房间
    </button>
  </view>

  <view class="section">
    <view class="section-title">加入房间</view>
    <input
      class="input"
      type="number"
      maxlength="6"
      placeholder="输入 6 位房号"
      value="{{roomCode}}"
      bindinput="handleRoomCodeInput"
    />
    <button class="secondary-button" loading="{{joining}}" disabled="{{creating || joining}}" bindtap="handleJoinRoom">
      加入房间
    </button>
  </view>
</view>
