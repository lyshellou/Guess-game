<view class="page lobby-page">
  <view class="header">
    <view class="header-kicker">多人房间框架</view>
    <text class="title">房间大厅</text>
    <text class="subtitle">创建房间后邀请朋友加入，后续游戏会直接接入当前房间状态。</text>
    <view class="status-line">
      <text>最多 8 人</text>
      <text>6 位房号</text>
      <text>云开发</text>
    </view>
  </view>

  <view class="section action-panel create-panel">
    <view>
      <view class="section-title">创建新房间</view>
      <text class="muted">自动生成房号，并以房主身份进入等待区。</text>
    </view>
    <button class="primary-button hero-button" loading="{{creating}}" disabled="{{creating || joining}}" bindtap="handleCreateRoom">
      <text class="button-title">创建房间</text>
      <text class="button-subtitle">立即生成房号</text>
    </button>
  </view>

  <view class="section action-panel">
    <view class="section-title">加入已有房间</view>
    <view class="join-row">
      <input
        class="input room-input"
        type="number"
        maxlength="6"
        placeholder="输入 6 位房号"
        value="{{roomCode}}"
        bindinput="handleRoomCodeInput"
      />
      <button class="secondary-button join-button" loading="{{joining}}" disabled="{{creating || joining}}" bindtap="handleJoinRoom">
        加入
      </button>
    </view>
    <text class="muted">输入朋友分享的房号即可进入同一个房间。</text>
  </view>
</view>
