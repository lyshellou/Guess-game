page {
  min-height: 100vh;
  color: #20242a;
  background: #f7f8fa;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  font-size: 28rpx;
}

button {
  border-radius: 16rpx;
  font-weight: 600;
}

button::after {
  border: 0;
}

button[disabled] {
  color: rgba(255, 255, 255, 0.78) !important;
  opacity: 0.72;
}

.page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 40rpx 32rpx;
}

.section {
  padding: 30rpx;
  margin-bottom: 24rpx;
  background: #ffffff;
  border: 1rpx solid #e7e9ee;
  border-radius: 16rpx;
}

.section-title {
  margin-bottom: 20rpx;
  color: #171a1f;
  font-size: 34rpx;
  font-weight: 600;
}

.muted {
  color: #6f7785;
  font-size: 24rpx;
  line-height: 1.6;
}

.primary-button {
  height: 88rpx;
  line-height: 88rpx;
  color: #ffffff;
  background: #1f6feb;
  font-size: 30rpx;
}

.secondary-button {
  height: 80rpx;
  line-height: 80rpx;
  color: #1d2633;
  background: #edf2f8;
  font-size: 28rpx;
}

.danger-button {
  height: 80rpx;
  line-height: 80rpx;
  color: #ffffff;
  background: #d92d20;
  font-size: 28rpx;
}

.input {
  box-sizing: border-box;
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  margin-bottom: 20rpx;
  background: #f8fafc;
  border: 1rpx solid #d7dee8;
  border-radius: 16rpx;
  color: #20242a;
  font-size: 30rpx;
}
